APP_NAME=SIGERD
APP_ENV=local
APP_DEBUG=true
APP_URL=http://sigerd.local
APP_BASE_PATH=
APP_TIMEZONE=America/Fortaleza

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sigerd
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

SESSION_COOKIE=sigerd_session
SESSION_LIFETIME=120
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Lax

AUTH_LOGIN_FIELD=email_login
AUTH_PASSWORD_MIN_LENGTH=8
AUTH_MAX_ATTEMPTS=5

AUDIT_ENABLED=true

ENTERPRISE_API_HEADER_NAME=X-Api-Key
ENTERPRISE_API_PREFIX_LENGTH=12
ENTERPRISE_API_TOKEN_PEPPER=
